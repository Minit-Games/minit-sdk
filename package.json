{
  "name": "@minit-games/sdk",
  "version": "1.2.0",
  "description": "Official SDK for building Minit Games HTML5 mini-games",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ui": {
      "import": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "tsc --project tsconfig.json --noEmit",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "minit",
    "games",
    "sdk",
    "html5"
  ],
  "author": "Drop GmbH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Minit-Games/minit-sdk.git"
  },
  "homepage": "https://github.com/Minit-Games/minit-sdk",
  "dependencies": {
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/seedrandom": "^3.0.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0"
  }
}
